-- Hàm tính vị trí đứng
local function getDesiredPosition(targetPos, targetCFrame)
    if farmPosition == "Behind" and targetCFrame then
        local behindOffset = targetCFrame.LookVector * -farmRange
        return targetPos + behindOffset
    elseif farmPosition == "Under" then
        return Vector3.new(targetPos.X, targetPos.Y - farmRange, targetPos.Z)
    else
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local direction = (targetPos - hrp.Position).Unit
            return targetPos - direction * farmRange
        end
        return targetPos + Vector3.new(farmRange, 0, farmRange)
    end
end

-- Di chuyển đến boss
local function moveToTarget(target)
    if not LocalPlayer or not LocalPlayer.Character then return false end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local desiredPos = getDesiredPosition(target.Position, target.CFrame)
    local distance = (hrp.Position - desiredPos).Magnitude
    
    if distance > 5 then
        hrp.CFrame = CFrame.new(desiredPos)
        return false
    end
    return true
end

-- Tấn công boss
local function attackBoss(target)
    if not target or not target.Humanoid then return end
    if target.Humanoid.Health <= 0 then return false end
    
    local remote = ReplicatedStorage:FindFirstChild("Attack") or ReplicatedStorage:FindFirstChild("Damage")
    if remote then
        remote:FireServer(target.Object)
    end
    return true
end

-- Hàm farm tổng quát
local function startFarmLoop(getTargetFunc, isActiveFunc, farmName)
    task.spawn(function()
        while isActiveFunc() do
            local target = getTargetFunc()
            if target then
                local atPosition = moveToTarget(target)
                if atPosition then
                    attackBoss(target)
                    wait(0.3)
                else
                    wait(0.5)
                end
            else
                print("[Farm] Không tìm thấy", farmName, "đang quét lại...")
                wait(5)
            end
        end
    end)
end

