-- ========== FARM KATAKURI (CAKE PRINCE + DOUGH KING) ==========
local isFarmingKatakuri = false
local currentBossStep = "cake"
local cakeKillCount = 0
local doughKillCount = 0

local BossData = {
    cake = {
        Name = "Cake Prince",
        Location = Vector3.new(-6000, 80, -200),
        DoorPosition = Vector3.new(-5800, 80, -180),
        BossRoomPosition = Vector3.new(-5700, 100, -150),
        RequiredKills = 500,
        EnemyNames = {"Cake Guard", "Cake Soldier", "Cake Warrior", "Cake Mage", "Cake Knight"},
        BossNames = {"Cake Prince", "Katakuri", "Dogtooth"}
    },
    dough = {
        Name = "Dough King",
        Location = Vector3.new(-12500, 200, -500),
        AltarPosition = Vector3.new(-12700, 200, -600),
        RequiredKills = 500,
        EnemyNames = {"Dough Soldier", "Dough Mage", "Dough Warrior"},
        BossNames = {"Dough King", "DoughKing", "Dough King V1", "Dough King V2"}
    }
}

local function findBossEnemy(bossType)
    local char = LocalPlayer.Character
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    local data = BossData[bossType]
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("Model") and obj:FindFirstChild("Humanoid") then
            local name = obj.Name
            for _, enemyName in ipairs(data.EnemyNames) do
                if name and name:find(enemyName) then
                    local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                    local hum = obj:FindFirstChild("Humanoid")
                    if hrp and hum and hum.Health > 0 then
                        return {Object = obj, Part = hrp, Position = hrp.Position, CFrame = hrp.CFrame}
                    end
                end
            end
        end
    end
    return nil
end

local function findBoss(bossType)
    local data = BossData[bossType]
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local name = obj.Name
        for _, bossName in ipairs(data.BossNames) do
            if name and name:find(bossName) then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                if hrp then
                    local hum = obj:FindFirstChild("Humanoid")
                    if hum and hum.Health > 0 then
                        return {Object = obj, Position = hrp.Position, CFrame = hrp.CFrame, Humanoid = hum}
                    end
                end
            end
        end
    end
    return nil
end

local function openCakeDoor()
    print("[Katakuri] Mở cổng Cake Prince, cần 500 kill")
    teleportTo(BossData.cake.Location)
    task.wait(1)
    while isFarmingKatakuri and currentBossStep == "cake" do
        local enemy = findBossEnemy("cake")
        if enemy then
            teleportTo(enemy.Position)
            task.wait(0.3)
            performAttack(enemy.Part, enemy.Object)
            cakeKillCount = cakeKillCount + 1
            if cakeKillCount % 50 == 0 then
                print("[Katakuri] Kill:", cakeKillCount, "/500")
            end
        else
            task.wait(2)
        end
        local door = Workspace:FindFirstChild("MirrorDoor") or Workspace:FindFirstChild("CakeDoor")
        if door then
            print("[Katakuri] Cổng mở!")
            teleportTo(BossData.cake.DoorPosition)
            task.wait(1)
            teleportTo(BossData.cake.BossRoomPosition)
            break
        end
    end
end

local function summonDoughKingBoss()
    print("[Katakuri] Triệu hồi Dough King, cần 500 kill")
    teleportTo(BossData.dough.Location)
    task.wait(1)
    while isFarmingKatakuri and currentBossStep == "dough" and doughKillCount < 500 do
        local enemy = findBossEnemy("dough")
        if enemy then
            teleportTo(enemy.Position)
            task.wait(0.3)
            performAttack(enemy.Part, enemy.Object)
            doughKillCount = doughKillCount + 1
            if doughKillCount % 50 == 0 then
                print("[Katakuri] Kill Dough:", doughKillCount, "/500")
            end
        else
            task.wait(2)
        end
    end
    if doughKillCount >= 500 then
        print("[Katakuri] Đủ kill, tìm drip_mama...")
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj.Name and (obj.Name:find("drip_mama") or obj.Name:find("DripMama")) then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                if hrp then
                    teleportTo(hrp.Position - Vector3.new(0, 0, 5))
                    task.wait(0.5)
                    local remote = ReplicatedStorage:FindFirstChild("SummonDoughKing") or ReplicatedStorage:FindFirstChild("ActivateAltar")
                    if remote then pcall(function() remote:FireServer(obj) end) end
                    break
                end
            end
        end
    end
end

local katakuriLoopRunning = false
local function startKatakuriFarming()
    if katakuriLoopRunning then return end
    katakuriLoopRunning = true
    isFarmingKatakuri = true
    currentBossStep = "cake"
    cakeKillCount = 0
    doughKillCount = 0
    print("[Katakuri] Bắt đầu farm - Cake Prince -> Dough King")
    task.spawn(function()
        while isFarmingKatakuri do
            if currentBossStep == "cake" then
                local boss = findBoss("cake")
                if boss then
                    teleportTo(boss.Position - Vector3.new(10, 0, 10))
                    task.wait(0.3)
                    local part = boss.Object:FindFirstChild("HumanoidRootPart") or boss.Object:FindFirstChild("Head")
                    performAttack(part, boss.Object)
                    task.wait(0.3)
                else
                    openCakeDoor()
                    task.wait(2)
                end
                if findBoss("cake") == nil and cakeKillCount >= 500 then
                    print("[Katakuri] Chuyển sang Dough King")
                    currentBossStep = "dough"
                end
            elseif currentBossStep == "dough" then
                local boss = findBoss("dough")
                if boss then
                    teleportTo(boss.Position - Vector3.new(10, 0, 10))
                    task.wait(0.3)
                    local part = boss.Object:FindFirstChild("HumanoidRootPart") or boss.Object:FindFirstChild("Head")
                    performAttack(part, boss.Object)
                    task.wait(0.3)
                else
                    summonDoughKingBoss()
                    task.wait(2)
                end
            end
            task.wait(0.5)
        end
        katakuriLoopRunning = false
    end)
end

local function stopKatakuriFarming()
    isFarmingKatakuri = false
    print("[Katakuri] Dừng farm")
end

-- ========== ESP SYSTEM ==========
local ESP = {Enabled = {Player = false, Fruit = false, Chest = false, Flower = false}, Objects = {}}
local espColors = {Player = Color3.fromRGB(255,50,50), Fruit = Color3.fromRGB(255,150,50), Chest = Color3.fromRGB(50,255,50), Flower = Color3.fromRGB(255,50,255)}

local function createESPBox(obj, color, text)
    if not obj or not obj.Parent then return nil end
    local box = Instance.new("BoxHandleAdornment")
    box.Size = Vector3.new(4,4,4)
    box.Color3 = color
    box.AlwaysOnTop = true
    box.Transparency = 0.5
    box.Adornee = obj
    local bill = Instance.new("BillboardGui")
    bill.Size = UDim2.new(0,100,0,30)
    bill.StudsOffset = Vector3.new(0,2.5,0)
    bill.AlwaysOnTop = true
    bill.Parent = box
    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1,0,1,0)
    label.BackgroundTransparency = 1
    label.TextColor3 = color
    label.Text = text
    label.Font = Enum.Font.GothamBold
    label.TextSize = 11
    label.Parent = bill
    return box
end

local function clearESP()
    for _, obj in pairs(ESP.Objects) do if obj and obj.Parent then obj:Destroy() end end
    ESP.Objects = {}
end

local function updateESP()
    clearESP()
    if ESP.Enabled.Player then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character then
                local hrp = plr.Character:FindFirstChild("HumanoidRootPart") or plr.Character:FindFirstChild("Head")
                if hrp then
                    local box = createESPBox(hrp, espColors.Player, "👤 " .. plr.Name)
                    if box then table.insert(ESP.Objects, box) end
                end
            end
        end
    end
    if ESP.Enabled.Fruit then
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj.Name:lower():find("fruit") then
                local box = createESPBox(obj, espColors.Fruit, "🍎 Fruit")
                if box then table.insert(ESP.Objects, box) end
            end
        end
    end
end

task.spawn(function()
    while true do
        if ESP.Enabled.Player or ESP.Enabled.Fruit or ESP.Enabled.Chest or ESP.Enabled.Flower then
            pcall(updateESP)
        else
            clearESP()
        end
        task.wait(0.5)
    end
end)

