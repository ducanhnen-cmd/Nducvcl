-- ========== VŨ KHÍ ==========
local selectedWeapon = "Melee"
local currentTool = nil

local weaponKeywords = {
    Melee = {"Melee", "Combat", "Fighting", "Black Leg", "Electro", "Dragon Claw", "Death Step", "Superhuman", "Godhuman"},
    Sword = {"Sword", "Katana", "Blade", "Saber", "Dark Blade", "Tushita", "Yama", "Cdk", "Gravity", "Rengoku", "Shisui"},
    Gun = {"Gun", "Pistol", "Flintlock", "Kabucha", "Soul Guitar", "Bazooka", "Acidum"},
    Fruit = {"Fruit", "Blox Fruit", "Buddha", "Magma", "Ice", "Dragon", "Leopard", "Dough", "Venom"}
}

local function equipWeapon()
    local char = LocalPlayer.Character
    if not char then return end
    local backpack = LocalPlayer.Backpack
    local keywords = weaponKeywords[selectedWeapon] or weaponKeywords.Melee
    
    local current = char:FindFirstChildOfClass("Tool")
    if current then
        for _, kw in ipairs(keywords) do
            if current.Name:lower():find(kw:lower()) then
                currentTool = current
                return
            end
        end
    end
    
    for _, tool in ipairs(backpack:GetChildren()) do
        if tool:IsA("Tool") then
            for _, kw in ipairs(keywords) do
                if tool.Name:lower():find(kw:lower()) then
                    tool.Parent = char
                    task.wait(0.2)
                    currentTool = tool
                    return
                end
            end
        end
    end
end

LocalPlayer.CharacterAdded:Connect(function() task.wait(0.5) equipWeapon() end)

-- ========== AUTO FARM LEVEL ==========
local farmLevelEnabled = false
local farmNearMobEnabled = false
local farmBoneEnabled = false
local autoRespawnEnabled = false
local fastAttackEnabled = true
local autoClickM1Enabled = false
local farmRange = 15
local farmPosition = "Above"

local lastAttackTime = 0
local attackCooldown = 0.12

local function performAttack(targetPart, targetModel)
    if not hitRemote then return end
    local char = LocalPlayer.Character
    if not char then return end
    
    if not currentTool or not currentTool.Parent then
        equipWeapon()
    end
    
    local now = tick()
    if fastAttackEnabled then
        if now - lastAttackTime < attackCooldown then return end
    else
        if now - lastAttackTime < 0.5 then return end
    end
    lastAttackTime = now
    
    if autoClickM1Enabled then
        VirtualInput:SendMouseButtonEvent(0, 0, 0, true, game, 0)
        task.wait(0.03)
        VirtualInput:SendMouseButtonEvent(0, 0, 0, false, game, 0)
    end
    
    local uniqueId = tostring(LocalPlayer.UserId):sub(2,4) .. tostring(os.clock()*1000):sub(8,12)
    pcall(function()
        if attackRemote then attackRemote:FireServer() end
        hitRemote:FireServer(targetPart, {{targetModel, targetPart}}, nil, nil, uniqueId)
    end)
end

local function teleportTo(pos)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if hrp then hrp.CFrame = CFrame.new(pos) end
end

local function getFarmPosition(targetPos, targetCFrame)
    if farmPosition == "Behind" and targetCFrame then
        return targetPos + targetCFrame.LookVector * -farmRange
    elseif farmPosition == "Under" then
        return Vector3.new(targetPos.X, targetPos.Y - farmRange, targetPos.Z)
    else
        local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        if hrp then
            local dir = (targetPos - hrp.Position).Unit
            return targetPos - dir * farmRange
        end
        return targetPos + Vector3.new(farmRange, farmRange, farmRange)
    end
end

local function moveToTarget(targetPos, targetCFrame)
    local hrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    local desired = getFarmPosition(targetPos, targetCFrame)
    if (hrp.Position - desired).Magnitude > 5 then
        hrp.CFrame = CFrame.new(desired)
        return false
    end
    return true
end

local function getNearestEnemy()
    local char = LocalPlayer.Character
    local rootPart = char and char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return nil end
    
    local nearest = nil
    local nearestDist = farmRange
    
    local enemies = Workspace:FindFirstChild("Enemies")
    if enemies then
        for _, enemy in ipairs(enemies:GetChildren()) do
            local hrp = enemy:FindFirstChild("HumanoidRootPart") or enemy:FindFirstChild("Head")
            local hum = enemy:FindFirstChild("Humanoid")
            if hrp and hum and hum.Health > 0 then
                local dist = (hrp.Position - rootPart.Position).Magnitude
                if dist < nearestDist then
                    nearestDist = dist
                    nearest = {Model = enemy, Part = hrp, Pos = hrp.Position, CFrame = hrp.CFrame}
                end
            end
        end
    end
    
    if not nearest then
        for _, obj in ipairs(Workspace:GetDescendants()) do
            if obj:IsA("Model") and obj:FindFirstChild("Humanoid") and obj ~= char then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                local hum = obj:FindFirstChild("Humanoid")
                if hrp and hum and hum.Health > 0 then
                    local dist = (hrp.Position - rootPart.Position).Magnitude
                    if dist < nearestDist then
                        nearestDist = dist
                        nearest = {Model = obj, Part = hrp, Pos = hrp.Position, CFrame = hrp.CFrame}
                    end
                end
            end
        end
    end
    return nearest
end

local farmLoopRunning = false
local function startFarmLoop()
    if farmLoopRunning then return end
    farmLoopRunning = true
    task.spawn(function()
        while farmLevelEnabled or farmNearMobEnabled do
            local target = getNearestEnemy()
            if target then
                if moveToTarget(target.Pos, target.CFrame) then
                    performAttack(target.Part, target.Model)
                end
            end
            task.wait(fastAttackEnabled and 0.05 or 0.1)
        end
        farmLoopRunning = false
    end)
end

