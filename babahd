-- Silent Aim Hook
local hookSetup = false

local function setupSilentAimHook()
    if hookSetup then return end
    hookSetup = true
    
    local oldIndex = nil
    oldIndex = hookmetamethod(game, "__index", function(...)
        local args = {...}
        local self = args[1]
        local key = args[2]
        
        if silentAimEnabled and checkcaller() then
            if typeof(self) == "Instance" and (self:IsA("Projectile") or (self:IsA("Part") and self.Name:lower():find("bullet"))) then
                local target = getSilentAimTarget()
                if target and math.random(1, 100) <= silentAimHitChance then
                    local direction = (target.Position - self.Position).Unit
                    local speed = self.Velocity.Magnitude
                    if speed > 0 then
                        self.Velocity = direction * speed
                    else
                        task.defer(function()
                            if self and self.Parent then
                                self.Velocity = direction * 500
                            end
                        end)
                    end
                end
            end
        end
        
        return oldIndex(...)
    end)
    
    local oldFindPartOnRay = Workspace.FindPartOnRayWithIgnoreList
    local mt = getrawmetatable(Workspace)
    local oldIndex2 = mt.__index
    
    setreadonly(mt, false)
    mt.__index = function(self, key)
        if key == "FindPartOnRayWithIgnoreList" and silentAimEnabled and checkcaller() then
            return function(workspace, ray, ignoreList, ...)
                local target = getSilentAimTarget()
                if target and math.random(1, 100) <= silentAimHitChance then
                    local playerChar = player.Character
                    if playerChar then
                        local gunPos = playerChar:FindFirstChild("HumanoidRootPart") or playerChar:FindFirstChild("Head")
                        if gunPos then
                            local newRay = Ray.new(gunPos.Position, (target.Position - gunPos.Position).Unit * 1000)
                            return oldFindPartOnRay(workspace, newRay, ignoreList, ...)
                        end
                    end
                end
                return oldFindPartOnRay(workspace, ray, ignoreList, ...)
            end
        end
        return oldIndex2(self, key)
    end
    setreadonly(mt, true)
end

setupSilentAimHook()

RunService.RenderStepped:Connect(function()
    local localChar = player.Character
    local localHrp = localChar and localChar:FindFirstChild("HumanoidRootPart")
    
    -- FOV Circle
    if aimbotEnabled then
        local screenCenter = Camera.ViewportSize / 2
        fovCircle.Position = UDim2.new(0, screenCenter.X, 0, screenCenter.Y)
        fovCircle.Size = UDim2.new(0, aimbotFov * 2, 0, aimbotFov * 2)
        fovStroke.Color = aimColor
        fovCircle.Visible = true
    else
        fovCircle.Visible = false
    end
    
    -- Silent Aim FOV Circle
    if silentAimEnabled then
        local screenCenter = Camera.ViewportSize / 2
        silentFovCircle.Position = UDim2.new(0, screenCenter.X, 0, screenCenter.Y)
        silentFovCircle.Size = UDim2.new(0, silentAimFovRadius * 2, 0, silentAimFovRadius * 2)
        silentFovCircle.Visible = true
    else
        silentFovCircle.Visible = false
    end
    
    -- ESP Update
    local currentTime = tick()
    if currentTime - lastESPUpdate >= ESP_UPDATE_INTERVAL then
        checkAndUpdateESP()
        lastESPUpdate = currentTime
    end
    
    -- Cập nhật hiển thị ESP
    for plr, data in pairs(espObjects) do
        if not plr.Character or not data.hrp or not data.hrp.Parent then
            removeESP(plr)
            continue
        end
        
        if localHrp then
            local dist = (data.hrp.Position - localHrp.Position).Magnitude
            local inRange = dist <= espMaxDist
            
            if data.highlight and data.highlight.Parent then
                data.highlight.Enabled = showBox and espEnabled and inRange
            end
            if data.tracer and data.tracer.Parent then
                data.tracer.Enabled = showTracer and espEnabled and inRange
            end
            if data.nameLabel then
                data.nameLabel.Visible = showNames and espEnabled and inRange
            end
            if data.healthLabel then
                data.healthLabel.Visible = showHealth and espEnabled and inRange
            end
        end
        
        if data.hum and data.hum.Parent and data.hum.Health > 0 then
            data.healthLabel.Text = "♥ " .. math.floor(data.hum.Health)
        end
    end
    
    -- Aimbot Logic
    if not aimbotEnabled then return end
    
    local shouldAim = false
    if isMobile then
        shouldAim = mobileAimHeld or autoAimEnabled
    else
        shouldAim = UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) or autoAimEnabled
    end
    
    if not shouldAim then return end
    if not localHrp then return end
    
    local screenCenter = Camera.ViewportSize / 2
    local bestHeadPos = nil
    local bestDist = math.huge
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == player then continue end
        if aimIgnoreTeam and plr.Team and player.Team and plr.Team == player.Team then continue end
        
        local char = plr.Character
        if not char then continue end
        local head = char:FindFirstChild("Head")
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not head or not hum or hum.Health <= 0 then continue end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp and localHrp then
            local worldDist = (hrp.Position - localHrp.Position).Magnitude
            if worldDist > aimbotMaxDist then continue end
        end
        
        local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
        if not onScreen then continue end
        
        local distFromCenter = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        if distFromCenter < aimbotFov and distFromCenter < bestDist then
            bestDist = distFromCenter
            bestHeadPos = head.Position
        end
    end
    
    if not bestHeadPos then return end
    
    if isMobile then
        local lookAt = CFrame.new(Camera.CFrame.Position, bestHeadPos)
        Camera.CFrame = Camera.CFrame:Lerp(lookAt, aimbotSmooth)
    else
        local targetScreenPos = Camera:WorldToViewportPoint(bestHeadPos)
        local mousePos = UserInputService:GetMouseLocation()
        local delta = (Vector2.new(targetScreenPos.X, targetScreenPos.Y) - mousePos) * (1 - aimbotSmooth)
        mousemoverel(delta.X, delta.Y)
    end
end)

-- ==================== INSTANT KILL LOOP ====================
spawn(function()
    while true do
        task.wait(0.2)
        
        if not instantKillEnabled then
            if followConnection then 
                followConnection:Disconnect()
                followConnection = nil
            end
            currentTarget = nil
            resetCamera()
            continue
        end
        
        updateAllTargets()
        
        if #allTargets == 0 then
            if followConnection then 
                followConnection:Disconnect()
                followConnection = nil
            end
            currentTarget = nil
            resetCamera()
            continue
        end
        
        if currentTarget and isValidTarget(currentTarget) then
            continue
        end
        
        local found = false
        for i = 1, #allTargets do
            local index = (currentIndex + i - 1) % #allTargets + 1
            local model = allTargets[index]
            
            if isValidTarget(model) then
                followTarget(model)
                currentIndex = index
                found = true
                break
            end
        end
        
        if not found then
            if followConnection then 
                followConnection:Disconnect()
                followConnection = nil
            end
            currentTarget = nil
            resetCamera()
        end
    end
end)

-- ==================== EVENTS ====================
Players.PlayerAdded:Connect(function(plr)
    plr.CharacterAdded:Connect(function(char)
        task.wait(1)
        if espEnabled then
            local sameTeam = false
            if espIgnoreTeam and plr.Team and player.Team and plr.Team == player.Team then
                sameTeam = true
            end
            if not sameTeam then
                createESP(plr)
            end
        end
    end)
    
    plr.CharacterRemoving:Connect(function()
        removeESP(plr)
    end)
end)

Players.PlayerRemoving:Connect(function(plr)
    removeESP(plr)
end)

player.CharacterAdded:Connect(function(newChar)
    task.wait(0.5)
    resetCamera()
    
    if espEnabled then
        refreshAllESP()
    end
    
    if instantKillEnabled then
        updateAllTargets()
    end
end)

player.CharacterRemoving:Connect(function()
    for plr, data in pairs(espObjects) do
        if data.attachment1 and data.attachment1.Parent then
            data.attachment1:Destroy()
        end
    end
end)

