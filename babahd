-- ==================== LOBBY DETECTION ====================
local function isInLobby(model)
    if not model then return false end
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local lobbyParts = {"Lobby", "Spawn", "WaitingRoom", "Waiting", "Lounge"}
    for _, partName in ipairs(lobbyParts) do
        local lobbyObj = Workspace:FindFirstChild(partName, true)
        if lobbyObj then
            local lobbyPos = lobbyObj.Position
            local dist = (hrp.Position - lobbyPos).Magnitude
            if dist <= 300 then
                return true
            end
        end
    end
    
    return false
end

local function isRealPlayer(model)
    return Players:GetPlayerFromCharacter(model) ~= nil
end

local function isPlayerActive(model)
    if not model then return false end
    local hrp = model:FindFirstChild("HumanoidRootPart")
    if not hrp then return false end
    
    local velocity = hrp.Velocity
    local speed = velocity.Magnitude
    
    if speed >= 3 then
        return true
    end
    
    if not isInLobby(model) then
        return true
    end
    
    return false
end

