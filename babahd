-- ==================== SILENT AIM FUNCTIONS ====================
local function getSilentAimTarget()
    local localChar = player.Character
    if not localChar then return nil end
    local localHrp = localChar:FindFirstChild("HumanoidRootPart")
    if not localHrp then return nil end
    
    local screenCenter = Camera.ViewportSize / 2
    local bestTarget = nil
    local bestDist = math.huge
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr == player then continue end
        if silentAimIgnoreTeam and plr.Team and player.Team and plr.Team == player.Team then continue end
        
        local char = plr.Character
        if not char then continue end
        
        local targetPart = char:FindFirstChild("Head")
        if not targetPart then continue end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health <= 0 then continue end
        
        local worldDist = (targetPart.Position - localHrp.Position).Magnitude
        if worldDist > silentAimMaxDist then continue end
        
        local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
        if not onScreen then continue end
        
        local distFromCenter = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
        if distFromCenter < silentAimFovRadius and distFromCenter < bestDist then
            bestDist = distFromCenter
            bestTarget = targetPart
        end
    end
    
    return bestTarget
end

-- ==================== ESP FUNCTIONS ====================
local function removeESP(plr)
    local data = espObjects[plr]
    if not data then return end
    if data.highlight and data.highlight.Parent then data.highlight:Destroy() end
    if data.billboard and data.billboard.Parent then data.billboard:Destroy() end
    if data.tracer and data.tracer.Parent then data.tracer:Destroy() end
    if data.attachment0 and data.attachment0.Parent then data.attachment0:Destroy() end
    if data.attachment1 and data.attachment1.Parent then data.attachment1:Destroy() end
    espObjects[plr] = nil
end

local function createESP(plr)
    if plr == player then return end
    if espIgnoreTeam and plr.Team and player.Team and plr.Team == player.Team then return end
    
    removeESP(plr)
    
    local char = plr.Character
    if not char then return end
    local head = char:FindFirstChild("Head")
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not head or not hrp or not hum then return end
    if hum.Health <= 0 then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Name = "ESP_Highlight"
    highlight.Adornee = char
    highlight.FillColor = espColor
    highlight.FillTransparency = 0.8
    highlight.OutlineColor = espColor
    highlight.OutlineTransparency = 0
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Enabled = showBox and espEnabled
    highlight.Parent = char
    
    local bill = Instance.new("BillboardGui")
    bill.Name = "ESP_Bill"
    bill.Adornee = head
    bill.AlwaysOnTop = true
    bill.Size = UDim2.new(0, 100, 0, 40)
    bill.StudsOffset = Vector3.new(0, 2, 0)
    bill.Parent = playerGui
    
    local nameLabel = Instance.new("TextLabel")
    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
    nameLabel.BackgroundTransparency = 1
    nameLabel.Text = plr.DisplayName
    nameLabel.TextColor3 = espColor
    nameLabel.Font = Enum.Font.GothamBold
    nameLabel.TextSize = 12
    nameLabel.TextStrokeTransparency = 0.4
    nameLabel.Visible = showNames
    nameLabel.Parent = bill
    
    local healthLabel = Instance.new("TextLabel")
    healthLabel.Size = UDim2.new(1, 0, 0.5, 0)
    healthLabel.Position = UDim2.new(0, 0, 0.5, 0)
    healthLabel.BackgroundTransparency = 1
    healthLabel.Text = "♥ " .. math.floor(hum.Health)
    healthLabel.TextColor3 = Color3.fromRGB(255, 80, 80)
    healthLabel.Font = Enum.Font.Code
    healthLabel.TextSize = 11
    healthLabel.Visible = showHealth
    healthLabel.Parent = bill
    
    local attachment0 = Instance.new("Attachment")
    attachment0.Parent = hrp
    
    local localHrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    local attachment1 = Instance.new("Attachment")
    attachment1.Parent = localHrp or hrp
    
    local tracer = Instance.new("Beam")
    tracer.Attachment0 = attachment0
    tracer.Attachment1 = attachment1
    tracer.Color = ColorSequence.new(espColor)
    tracer.Width0 = 0.1
    tracer.Width1 = 0.1
    tracer.Transparency = NumberSequence.new(0.4)
    tracer.Enabled = showTracer and espEnabled
    tracer.Parent = hrp
    
    espObjects[plr] = {
        highlight = highlight,
        billboard = bill,
        nameLabel = nameLabel,
        healthLabel = healthLabel,
        tracer = tracer,
        attachment0 = attachment0,
        attachment1 = attachment1,
        hrp = hrp,
        hum = hum
    }
end

function refreshAllESP()
    for plr in pairs(espObjects) do
        removeESP(plr)
    end
    
    if not espEnabled then return end
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            local sameTeam = false
            if espIgnoreTeam and plr.Team and player.Team and plr.Team == player.Team then
                sameTeam = true
            end
            if not sameTeam then
                createESP(plr)
            end
        end
    end
end

local function checkAndUpdateESP()
    for plr, data in pairs(espObjects) do
        local char = plr.Character
        
        if not char or not char:FindFirstChild("HumanoidRootPart") or not char:FindFirstChild("Head") then
            removeESP(plr)
            continue
        end
        
        local hum = char:FindFirstChildOfClass("Humanoid")
        if not hum or hum.Health <= 0 then
            removeESP(plr)
            continue
        end
        
        local newHrp = char:FindFirstChild("HumanoidRootPart")
        local newHum = char:FindFirstChildOfClass("Humanoid")
        local newHead = char:FindFirstChild("Head")
        
        if newHrp and newHrp ~= data.hrp then
            data.hrp = newHrp
            if data.attachment0 and data.attachment0.Parent then
                data.attachment0.Parent = newHrp
            end
            if data.tracer and data.tracer.Parent then
                data.tracer.Parent = newHrp
            end
        end
        
        if newHum and newHum ~= data.hum then
            data.hum = newHum
        end
        
        if newHead and data.billboard and data.billboard.Parent then
            data.billboard.Adornee = newHead
        end
    end
    
    if espEnabled then
        for _, plr in ipairs(Players:GetPlayers()) do
            if plr ~= player and not espObjects[plr] then
                local sameTeam = false
                if espIgnoreTeam and plr.Team and player.Team and plr.Team == player.Team then
                    sameTeam = true
                end
                if not sameTeam then
                    local char = plr.Character
                    if char then
                        local hum = char:FindFirstChildOfClass("Humanoid")
                        local hrp = char:FindFirstChild("HumanoidRootPart")
                        local head = char:FindFirstChild("Head")
                        if hum and hum.Health > 0 and hrp and head then
                            createESP(plr)
                        end
                    end
                end
            end
        end
    end
end

-- ==================== INSTANT KILL FUNCTIONS ====================
local function isTargetAlive(model)
    if not model then return false end
    local hrp = model:FindFirstChild("HumanoidRootPart")
    local hum = model:FindFirstChildOfClass("Humanoid")
    return hrp ~= nil and hum ~= nil and hum.Health > 0
end

local function isValidTarget(model)
    if not isTargetAlive(model) then return false end
    if model == player.Character then return false end
    
    if isInLobby(model) then return false end
    if isInLobby(player.Character) then return false end
    
    local plr = Players:GetPlayerFromCharacter(model)
    if plr then
        if plr == player then return false end
        if plr.Team and player.Team and plr.Team == player.Team then
            return false
        end
    else
        if model.Name ~= "Astration"
           and not model.Name:find("Astration")
           and not model.Name:find("Bot")
           and not model.Name:find("Dummy")
           and not model.Name:find("NPC") then
            return false
        end
    end
    
    return true
end

local function updateAllTargets()
    allTargets = {}
    
    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= player then
            local char = plr.Character
            if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChildOfClass("Humanoid") then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum and hum.Health > 0 then
                    if not isInLobby(char) then
                        table.insert(allTargets, char)
                    end
                end
            end
        end
    end
    
    for _, obj in ipairs(Workspace:GetChildren()) do
        if obj:IsA("Model")
            and obj:FindFirstChild("Humanoid")
            and obj:FindFirstChild("HumanoidRootPart")
            and not isRealPlayer(obj) then
            
            local hum = obj:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                if obj.Name == "Astration"
                   or obj.Name:find("Astration")
                   or obj.Name:find("Bot")
                   or obj.Name:find("Dummy")
                   or obj.Name:find("NPC") then
                    if not isInLobby(obj) then
                        table.insert(allTargets, obj)
                    end
                end
            end
        end
    end
end

local function resetCamera()
    Camera.CameraType = Enum.CameraType.Custom
end

local function followTarget(model)
    if followConnection then 
        followConnection:Disconnect()
        followConnection = nil
    end
    
    if not model or not model:FindFirstChild("HumanoidRootPart") then
        currentTarget = nil
        resetCamera()
        return
    end
    
    currentTarget = model
    Camera.CameraType = Enum.CameraType.Scriptable
    
    followConnection = RunService.Heartbeat:Connect(function()
        if not instantKillEnabled then
            if followConnection then 
                followConnection:Disconnect()
                followConnection = nil
            end
            currentTarget = nil
            resetCamera()
            return
        end
        
        if not isValidTarget(model) then
            if followConnection then 
                followConnection:Disconnect()
                followConnection = nil
            end
            currentTarget = nil
            resetCamera()
            return
        end
        
        local targetHRP = model:FindFirstChild("HumanoidRootPart")
        if not targetHRP then
            if followConnection then 
                followConnection:Disconnect()
                followConnection = nil
            end
            currentTarget = nil
            resetCamera()
            return
        end
        
        local targetHead = model:FindFirstChild("Head")
        local myChar = player.Character
        if not myChar then return end
        
        local myHRP = myChar:FindFirstChild("HumanoidRootPart")
        local myHead = myChar:FindFirstChild("Head")
        
        if not myHRP then return end
        
        myHRP.CanCollide = false
        
        local targetPos = targetHRP.Position
        local lookVector = targetHRP.CFrame.LookVector
        local myPos = targetPos + Vector3.new(0, HEIGHT_OFFSET, 0) - (lookVector * DISTANCE)
        
        myHRP.CFrame = CFrame.lookAt(myPos, targetPos)
        
        local myEyePos = myHead and myHead.Position or (myHRP.Position + Vector3.new(0, 2, 0))
        local targetLookPos = targetHead and targetHead.Position or (targetPos + Vector3.new(0, 1.5, 0))
        Camera.CFrame = CFrame.lookAt(myEyePos, targetLookPos)
    end)
end

