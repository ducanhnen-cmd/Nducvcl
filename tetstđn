        Position = UDim2.new(0,12,0,54), 
        BackgroundColor3 = Color3.fromRGB(45,45,45), 
        Visible = false,
        ZIndex = 10,
        ScrollBarThickness = 4,
        ClipsDescendants = true
    })
    new("UICorner", {Parent = menu, CornerRadius = UDim.new(0,8)})
    
    local menuList = new("UIListLayout", {Parent = menu})
    menuList.Padding = UDim.new(0, 2)
    
    for i,opt in ipairs(options) do
        local optBtn = new("TextButton", {
            Parent = menu, 
            Size = UDim2.new(1,-8,0,28), 
            BackgroundColor3 = Color3.fromRGB(55,55,55), 
            BackgroundTransparency = 0.5,
            Text = opt, 
            Font = Enum.Font.Gotham, 
            TextSize = 13, 
            TextColor3 = TXT, 
            AutoButtonColor = false,
            ZIndex = 10
        })
        new("UICorner", {Parent = optBtn, CornerRadius = UDim.new(0,6)})
        
        optBtn.MouseButton1Click:Connect(function()
            btn.Text = opt
            menu.Visible = false
            if callback then pcall(callback, opt) end
        end)
        
        optBtn.MouseEnter:Connect(function()
            optBtn.BackgroundColor3 = ACCENT
            optBtn.TextColor3 = Color3.fromRGB(20,20,20)
        end)
        optBtn.MouseLeave:Connect(function()
            optBtn.BackgroundColor3 = Color3.fromRGB(55,55,55)
            optBtn.TextColor3 = TXT
        end)
    end
    
    local menuHeight = math.min(#options * 30, 120)
    menu.Size = UDim2.new(1,-24,0,menuHeight)
    
    btn.MouseButton1Click:Connect(function()
        menu.Visible = not menu.Visible
        if menu.Visible then
            menu.ZIndex = 20
        end
    end)
    
    return {Row = row, Button = btn}
end

