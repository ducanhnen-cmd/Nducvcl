-- ========== HỆ THỐNG FARM KATAKURI VÀ ELITE ==========
local FarmMode = {
    Idle = "Idle",
    Moving = "Moving",
    Attacking = "Attacking"
}

local currentFarmMode = FarmMode.Idle
local currentTarget = nil
local isFarming = false
local farmType = nil -- "katakuri" or "elite"
local farmRange = 100

-- Danh sách tên boss cần tìm
local KatakuriNames = {"Katakuri", "Dogtooth", "Charlotte Katakuri", "Katakuri Boss"}
local EliteNames = {"Elite", "Elite Boss", "Boss Elite", "Thunder God", "Elite Hunter"}

-- Tìm Katakuri trong map
local function findKatakuri()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local name = obj.Name:lower()
        for _, katName in ipairs(KatakuriNames) do
            if name:find(katName:lower()) and (obj:IsA("Model") or obj:IsA("Part")) then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                if hrp then
                    return {Object = obj, Position = hrp.Position, Humanoid = obj:FindFirstChild("Humanoid")}
                elseif obj:IsA("BasePart") then
                    return {Object = obj, Position = obj.Position}
                end
            end
        end
    end
    return nil
end

-- Tìm Elite Boss trong map
local function findElite()
    for _, obj in ipairs(Workspace:GetDescendants()) do
        local name = obj.Name:lower()
        for _, eliteName in ipairs(EliteNames) do
            if name:find(eliteName:lower()) and (obj:IsA("Model") or obj:IsA("Part")) then
                local hrp = obj:FindFirstChild("HumanoidRootPart") or obj:FindFirstChild("Head")
                if hrp then
                    return {Object = obj, Position = hrp.Position, Humanoid = obj:FindFirstChild("Humanoid")}
                elseif obj:IsA("BasePart") then
                    return {Object = obj, Position = obj.Position}
                end
            end
        end
    end
    return nil
end

-- Quét toàn bộ map tìm boss
local function scanForBosses()
    print("[Farm] Đang quét toàn bộ map tìm boss...")
    local katakuri = findKatakuri()
    local elite = findElite()
    
    if katakuri then
        print("[Farm] Đã tìm thấy Katakuri tại:", katakuri.Position)
    else
        print("[Farm] Không tìm thấy Katakuri trong map")
    end
    
    if elite then
        print("[Farm] Đã tìm thấy Elite tại:", elite.Position)
    else
        print("[Farm] Không tìm thấy Elite trong map")
    end
    
    return katakuri, elite
end

-- Di chuyển đến vị trí boss
local function moveToTarget(targetPos)
    if not LocalPlayer or not LocalPlayer.Character then return end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.WalkSpeed = 50
    end
    
    local distance = (hrp.Position - targetPos).Magnitude
    if distance > farmRange then
        hrp.CFrame = CFrame.new(targetPos)
        return true
    end
    return distance <= farmRange
end

-- Tấn công boss
local function attackBoss(target)
    if not target or not target.Humanoid then return end
    
    -- Kiểm tra boss còn sống không
    if target.Humanoid.Health <= 0 then
        return false
    end
    
    -- Gọi sự kiện tấn công (tuỳ game)
    local args = {
        [1] = target.Object
    }
    -- Thử gọi remote (có thể cần chỉnh theo game)
    local remote = ReplicatedStorage:FindFirstChild("Attack") or ReplicatedStorage:FindFirstChild("Damage")
    if remote then
        remote:FireServer(unpack(args))
    end
    
    return true
end

-- Hàm farm chính
local function startFarming(type)
    if isFarming then
        print("[Farm] Đang chạy, không thể bắt đầu lại")
        return
    end
    
    isFarming = true
    farmType = type
    print("[Farm] Bắt đầu farm:", type)
    
    task.spawn(function()
        while isFarming do
            local target = nil
            if farmType == "katakuri" then
                target = findKatakuri()
            elseif farmType == "elite" then
                target = findElite()
            end
            
            if target then
                currentTarget = target
                currentFarmMode = FarmMode.Moving
                
                -- Di chuyển đến boss
                local distance = (LocalPlayer.Character.HumanoidRootPart.Position - target.Position).Magnitude
                if distance > farmRange then
                    moveToTarget(target.Position)
                    wait(0.5)
                else
                    currentFarmMode = FarmMode.Attacking
                    attackBoss(target)
                    wait(0.3)
                end
            else
                -- Không tìm thấy boss, quét lại sau 5 giây
                currentFarmMode = FarmMode.Idle
                print("[Farm] Không tìm thấy", farmType, ", đang quét lại...")
                scanForBosses()
                wait(5)
            end
        end
    end)
end

local function stopFarming()
    isFarming = false
    currentFarmMode = FarmMode.Idle
    currentTarget = nil
    print("[Farm] Đã dừng farm")
end

-- ========== HỆ THỐNG NHẬN DIỆN MAP ==========
local DetectedIslands = {
    Sea1 = {},
    Sea2 = {},
    Sea3 = {},
    Unknown = {}
}

local IslandList = {}

local function scanMap()
    print("[Scan] Đang quét toàn bộ map...")
    DetectedIslands = {Sea1 = {}, Sea2 = {}, Sea3 = {}, Unknown = {}}
    IslandList = {}
    
    local partCount = 0
    
    for _, obj in ipairs(Workspace:GetDescendants()) do
        if obj:IsA("BasePart") and obj.Name ~= "" then
            local pos = obj.Position
            local size = obj.Size
            
            if size.X > 50 and size.Z > 50 then
                local islandInfo = {
                    Name = obj.Name,
                    Position = pos,
                    Size = size,
                    ClassName = obj.ClassName
                }
                
                local absX = math.abs(pos.X)
                local absZ = math.abs(pos.Z)
                
                if absX < 5000 and absZ < 4000 then
                    table.insert(DetectedIslands.Sea1, islandInfo)
                    islandInfo.Sea = "Sea 1"
                elseif absX >= 5000 and absX < 10000 and absZ < 5000 then
                    table.insert(DetectedIslands.Sea2, islandInfo)
                    islandInfo.Sea = "Sea 2"
                elseif absX >= 10000 or absZ >= 5000 then
                    table.insert(DetectedIslands.Sea3, islandInfo)
                    islandInfo.Sea = "Sea 3"
                else
                    table.insert(DetectedIslands.Unknown, islandInfo)
                    islandInfo.Sea = "Unknown"
                end
                
                table.insert(IslandList, islandInfo)
                partCount = partCount + 1
            end
        end
    end
    
    print(string.format("[Scan] Hoàn thành! Đã tìm thấy %d đảo/part lớn", partCount))
    return IslandList
end

local function getCurrentPosition()
    if LocalPlayer and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        return LocalPlayer.Character.HumanoidRootPart.Position
    end
    return Vector3.new(0, 0, 0)
end

local function getCurrentSea()
    local pos = getCurrentPosition()
    local absX = math.abs(pos.X)
    local absZ = math.abs(pos.Z)
    
    if absX < 5000 and absZ < 4000 then
        return "Sea 1", pos
    elseif absX >= 5000 and absX < 10000 and absZ < 5000 then
        return "Sea 2", pos
    elseif absX >= 10000 or absZ >= 5000 then
        return "Sea 3", pos
    else
        return "Unknown", pos
    end
end

