local function updateResultDisplay()
    local total = #IslandList
    local sea1 = #DetectedIslands.Sea1
    local sea2 = #DetectedIslands.Sea2
    local sea3 = #DetectedIslands.Sea3
    local unknown = #DetectedIslands.Unknown
    
    totalInfo.Text = string.format([[
📊 THỐNG KÊ:
━━━━━━━━━━━━━━━━━━━━
🏝️ Tổng số đảo/phát hiện: %d
🌊 Sea 1: %d đảo
🌊 Sea 2: %d đảo
🌊 Sea 3: %d đảo
❓ Không xác định: %d
    ]], total, sea1, sea2, sea3, unknown)
    
    local detailText = "📋 DANH SÁCH CHI TIẾT:\n━━━━━━━━━━━━━━━━━━━━\n"
    
    if #IslandList > 0 then
        for i, island in ipairs(IslandList) do
            local seaIcon = "🌊"
            if island.Sea == "Sea 1" then seaIcon = "🔵"
            elseif island.Sea == "Sea 2" then seaIcon = "🟢"
            elseif island.Sea == "Sea 3" then seaIcon = "🔴"
            else seaIcon = "⚪"
            end
            detailText = detailText .. string.format("%s %s\n   📍 (%.0f, %.0f, %.0f)\n", 
                seaIcon, island.Name, island.Position.X, island.Position.Y, island.Position.Z)
            if i >= 30 then
                detailText = detailText .. "\n... và " .. (#IslandList - 30) .. " đảo khác"
                break
            end
        end
    else
        detailText = detailText .. "Chưa có dữ liệu. Hãy quét map!"
    end
    
    resultText.Text = detailText
    resultText.Size = UDim2.new(1,0,0, math.min(400, #IslandList * 50 + 50))
end

